DATABASE_URL=  # pooled connection string (used at runtime by the app)
DIRECT_URL=    # non-pooled direct connection string (used by drizzle-kit migrate only)
SESSION_SECRET=  # must be at least 32 random characters (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
NEXT_PUBLIC_APP_URL=  # no trailing slash, e.g. https://your-app.vercel.app
