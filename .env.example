# PostgreSQL connection string
# Example: postgres://user:password@localhost:5432/conventials
DATABASE_URL=postgres://user:password@localhost:5432/conventials

# Express session secret — use a long random string in production
SESSION_SECRET=change_me_to_a_long_random_string

# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=no-reply@yourdomain.com

# Public URL of the app — used to build badge links in emails
# Example (local dev): http://localhost:5173
APP_URL=http://localhost:5173

# Express server port
PORT=3001

# Seeded admin credentials (used by db:migrate to insert initial organizer)
ADMIN_EMAIL=admin@conventials.com
ADMIN_PASSWORD=changeme
